{
  "name": "airforce-bridge",
  "version": "0.1.0",
  "description": "api.airforce için tool-call destekli OpenAI + Anthropic uyumlu köprü sunucu",
  "type": "module",
  "private": true,
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "node --test test/*.test.js test/providers/*.test.js",
    "probe": "node -e \"import('./lib/probe.js').then(m => m.runProbe())\""
  },
  "engines": {
    "node": ">=20"
  }
}
