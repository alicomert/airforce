# --- Required ---
# api.airforce upstream API key (panel.api.airforce'tan alınır)
AIRFORCE_API_KEY=sk-air-xxxxxxxxxxxxxxxxxxxxxxxxx

# --- Server ---
PORT=2393
HOST=0.0.0.0

# Köprü kendi API key'lerini kullanır. İstemciler bu key'i Bearer/x-api-key olarak gönderir.
# Birden fazla key'i virgülle ayır. Boşsa anon erişim açılır (sadece localhost).
BRIDGE_API_KEYS=

# Admin panel girişi için ayrı bir bearer token. Boşsa BRIDGE_API_KEYS'in ilki kullanılır.
ADMIN_TOKEN=

# Panel'de düz username/password ile giriş için (opsiyonel ama önerilen).
# İkisi de set edildiğinde panel HTML iki alanlı form gösterir; başarılı login session token üretir.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# --- Upstream behavior ---
UPSTREAM_BASE_URL=https://api.airforce
UPSTREAM_TIMEOUT_MS=120000
UPSTREAM_MAX_ATTEMPTS=3
UPSTREAM_RETRY_BASE_MS=200

# --- Tool engine ---
# Her zaman bizim XML inject akışını kullan (native tool_calls'u bile bypass et).
# 0 = capable model'lerde native pass-through, sadece destek vermeyenlerde XML inject (akıllı mod).
# 1 = her zaman XML inject (uniform davranış, kullanıcının tercihi).
TOOL_ENGINE_FORCE_XML=1

# Tool şeması başlığı/wrapper'ı: "dsml" (ds2api uyumlu <|DSML|tool_calls>) veya "canonical" (<tool_calls>).
TOOL_ENGINE_FORMAT=canonical

# --- Probe ---
# Her N saatte bir tool-capability probe'unu çalıştır (varsayılan 24)
PROBE_INTERVAL_HOURS=24
# Boot'ta da bir kere çalıştır
PROBE_ON_BOOT=1
# Probe için per-model timeout
PROBE_TIMEOUT_MS=20000

# --- Logging ---
LOG_LEVEL=info
LOG_RING_SIZE=500
